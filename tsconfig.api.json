{
  "extends": "./tsconfig.json",
  "include": ["api/**/*.ts", "api-lib/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".vercel/output/functions",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "types": ["node"]
  }
}
